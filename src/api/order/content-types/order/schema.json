{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order",
    "description": "Customer orders"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "items": { "type": "json", "required": true },
    "subtotal": { "type": "decimal", "required": true },
    "tax": { "type": "decimal", "default": 0 },
    "total": { "type": "decimal", "required": true },
    "status": { "type": "enumeration", "enum": ["pending","paid","shipped","delivered","cancelled"], "default": "pending" },
    "razorpay_order_id": { "type": "string" },
    "razorpay_payment_id": { "type": "string" },
    "razorpay_signature": { "type": "string" },
    "customer": { "type": "relation", "relation": "manyToOne", "target": "api::customer.customer" },
    "tenant": { "type": "relation", "relation": "manyToOne", "target": "api::tenant.tenant" }
  }
}

