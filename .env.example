# Server
HOST=0.0.0.0
PORT=1337
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=your-salt-here
ADMIN_JWT_SECRET=your-jwt-secret
TRANSFER_TOKEN_SALT=your-transfer-salt
JWT_SECRET=your-jwt-secret

# Database (Supabase PostgreSQL)
DATABASE_CLIENT=postgres
DATABASE_URL=postgres://user:pass@host:5432/db
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Storage (Cloudflare R2)
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=bharatcms
R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://cdn.bharatcms.com

# Email (Resend)
RESEND_API_KEY=re_

# Payments (Razorpay)
RAZORPAY_KEY_ID=rzp_test_
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# AI (Groq - free tier)
GROQ_API_KEY=gsk_

# WhatsApp (Meta Cloud API)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=

# Business Info (for GST invoices)
BUSINESS_NAME=BharatCMS Pvt Ltd
BUSINESS_GSTIN=29ABCDE1234F1Z5
BUSINESS_STATE=Karnataka
BUSINESS_ADDRESS=Bangalore, India 560001
BUSINESS_EMAIL=billing@bharatcms.com
BUSINESS_PHONE=+91-9876543210

# Frontend URLs (for CORS)
FRONTEND_URL=http://localhost:3000
LANDING_URL=http://localhost:3001
